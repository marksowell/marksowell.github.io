---
import { icon } from "@fortawesome/fontawesome-svg-core";
import { faGithubAlt, faLinkedin, faXTwitter } from "@fortawesome/free-brands-svg-icons";
import { faEnvelope } from "@fortawesome/free-solid-svg-icons";

const siteUrl = "https://marksowell.com";
const canonicalUrl = new URL("/", siteUrl).toString();
const pageTitle = "Mark Sowell | Lead Penetration Tester and Cybersecurity Expert";
const pageDescription =
	"Official website of Mark Sowell, Lead Penetration Tester at Check Point Software. Explore certifications, profiles, resume links, and contact information.";
const previewImage = new URL("/images/preview-image.png", siteUrl).toString();
const sameAs = [
	"https://www.linkedin.com/in/marksowell/",
	"https://x.com/marksowell/",
	"https://www.credly.com/users/marksowell",
	"https://tryhackme.com/p/marksowell",
	"https://github.com/marksowell",
];

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Mark Sowell",
	url: canonicalUrl,
	image: new URL("/images/marksowell-cp-circle-border-inside.png", siteUrl).toString(),
	jobTitle: "Lead Penetration Tester",
	worksFor: {
		"@type": "Organization",
		name: "Check Point Software",
	},
	email: "mailto:mark@marksowell.com",
	description: pageDescription,
	sameAs,
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Mark Sowell",
	url: canonicalUrl,
	description: pageDescription,
};

const emailIcon = icon(faEnvelope, { classes: ["icon-svg"] }).html.join("");
const linkedinIcon = icon(faLinkedin, { classes: ["icon-svg"] }).html.join("");
const xIcon = icon(faXTwitter, { classes: ["icon-svg"] }).html.join("");
const githubIcon = icon(faGithubAlt, { classes: ["icon-svg"] }).html.join("");
---

<html lang="en">
	<head>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			window.gtag = function gtag() {
				window.dataLayer.push(arguments);
			};

			const loadAnalytics = () => {
				if (window.__gaLoaded) return;
				window.__gaLoaded = true;

				const script = document.createElement("script");
				script.async = true;
				script.src = "https://www.googletagmanager.com/gtag/js?id=G-3XQVKRQLEQ";
				document.head.append(script);

				window.gtag("js", new Date());
				window.gtag("config", "G-3XQVKRQLEQ");
			};

			window.addEventListener("load", loadAnalytics, { once: true });
		</script>

		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<meta name="robots" content="index,follow" />
		<meta name="author" content="Mark Sowell" />
		<meta name="referrer" content="strict-origin-when-cross-origin" />
		<meta name="theme-color" content="#1a222c" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="preload" href="https://fonts.gstatic.com/s/montserrat/v29/JTUHjIg1_i6t8kCHKm4532VJOt5-QNFgpCtr6Hw5aXp-p7K4KLg.woff2" as="font" type="font/woff2" crossorigin="anonymous">
		<link rel="preload" href="/styles/main.css" as="style">
		<link rel="stylesheet" href="/styles/main.css" />
		<link rel="icon" href="/images/favicon.avif" type="image/avif" />
		<!-- <link rel="icon" href="/images/favicon.png" type="image/png" /> -->
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/images/apple-touch-icon.png"
		/>
		<meta name="apple-mobile-web-app-title" content="Mark Sowell" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={previewImage} />
		<!-- Open Graph Tags -->
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:image" content={previewImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Mark Sowell" />
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} is:inline />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} is:inline />
		<script src="/js/main.js" defer is:inline></script>
	</head>
	<body>
		<div
			id="hero-grid"
			class="hero-grid"
			style="touch-action: manipulation; pointer-events: auto;"
		>
			<div class="hero-grid__veil" aria-hidden="true"></div>
			<div class="hero-grid__fade hero-grid__fade--left" aria-hidden="true"></div>
			<div class="hero-grid__fade hero-grid__fade--right" aria-hidden="true"></div>
			<div class="hero-grid__fade hero-grid__fade--top" aria-hidden="true"></div>
			<div class="hero-grid__fade hero-grid__fade--bottom" aria-hidden="true"></div>
				<svg
					id="hero-grid-svg"
					class="hero-grid__svg"
					aria-hidden="true"
					preserveAspectRatio="xMidYMid slice"
					viewBox="0 0 1800 1200"
				>
					<g id="hero-grid-static-nodes"></g>
					<g id="hero-grid-links"></g>
					<g id="hero-grid-nodes"></g>
				</svg>
			<div
				class="header"
				style="min-width:80%; height:100svh; pointer-events: none;"
			>
				<h1>
						<span style="margin-bottom: 10px;"
							>
							<picture>
								<source
									srcset="/images/marksowell-cp-circle-border-inside-512.webp"
									type="image/webp"
								/>
								<img
									src="/images/marksowell-cp-circle-border-inside-512.png"
									alt="Mark Sowell"
									width="512"
									height="512"
									fetchpriority="high"
									decoding="async"
									style="height: 250px; width: auto;"
								/>
							</picture>
						</span>
					<span style="margin-bottom:10px;" class="site-title"
						>Mark Sowell</span
					>
					<span
						style="margin:0 auto;max-width:80%;"
						class="site-description"
						>Lead Penetration Tester at Check Point Software - OSCP+, CEH Master, CCSM Elite, & Cybersecurity Expert</span
					>
				</h1>
				<div class="header-icons">
					<a
						aria-label="Send Email"
						href="mailto:mark@marksowell.com"
						title="Send Email"
						><span class="icon icon-svg-wrap" aria-hidden="true" set:html={emailIcon}></span></a
					>
					<a
						aria-label="My LinkedIn"
						target="_blank"
						rel="me noopener noreferrer"
						href="https://www.linkedin.com/in/marksowell/"
						title="My LinkedIn"
						><span class="icon icon-svg-wrap" aria-hidden="true" set:html={linkedinIcon}></span></a
					>
					<a
						aria-label="My X"
						target="_blank"
						rel="me noopener noreferrer"
						href="https://x.com/marksowell/"
						title="My X"
						><span class="icon icon-svg-wrap" aria-hidden="true" set:html={xIcon}></span></a
					>
					<a
						aria-label="My Credly"
						target="_blank"
						rel="me noopener noreferrer"
						href="https://www.credly.com/users/marksowell"
						title="My Credly"
						><i
							class="icon fa fa-mycredly"
							aria-hidden="true"></i></a
					>
					<a
						aria-label="EC-Council"
						target="_blank"
						rel="noopener noreferrer"
						href="https://aspen.eccouncil.org/VerifyBadge?type=certification&a=hrh5u5BN7tpBPrNa4iembfeuOXjVqqECsmvVrUh2oeI="
						title="EC-Council"
						><span class="icon icon-aspen" aria-hidden="true">&#9651;</span></a
					>
					<a
						aria-label="TryHackMe"
						target="_blank"
						rel="me noopener noreferrer"
						href="https://tryhackme.com/p/marksowell"
						title="TryHackMe"
						><i class="icon fa fa-thm" aria-hidden="true"></i></a
					>
					<!--<a aria-label="My Stackoverflow" target="_blank" href="https://stackoverflow.com/users/12828897/mark-s?tab=profile"><i class="icon fa fa-stack-overflow" aria-hidden="true"></i></a>-->
					<a
						aria-label="My GitHub"
						target="_blank"
						rel="me noopener noreferrer"
						href="https://github.com/marksowell"
						title="My GitHub"
						><span class="icon icon-svg-wrap" aria-hidden="true" set:html={githubIcon}></span></a
					>
					<!--<a aria-label="HackTheBox profile" target="_blank" href="https://www.hackthebox.eu/profile/319820"><i class="icon fa fa-cube" aria-hidden="true"></i></a>-->
					<!--<a aria-label="HackerRank profile" target="_blank" href="https://www.hackerrank.com/marksowell"><i class="icon fa fa-code" aria-hidden="true"></i></a>-->
					<!--<a aria-label="HackerOne profile" target="_blank" href="https://hackerone.com/marksowell"><i class="icon fa fa-bug" aria-hidden="true"></i></a>-->
				</div>
				<div
					class="status-container"
					style="width: 100%; padding-left: 30px; justify-content: center; position: absolute; display: flex; bottom: 10px; pointer-events: auto;"
				>
					<iframe
						src="https://status.marksowell.com/badge?theme=dark"
						width="250"
						height="30"
						style="border: 0;"
						title="Status"></iframe>
				</div>
			</div>
		</div>
	</body>
</html>
